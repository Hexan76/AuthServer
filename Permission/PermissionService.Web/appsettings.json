{
  "App": {
    "SelfUrl": "https://localhost:44366",
    "HealthCheckUrl": "/health-status",
    "SelfPermissionService": true
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "Logs/logs.txt"
              }
            }
          ]
        }
      },
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      }
    ]
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5433;Database=PermissionService;User ID=admin;Password=SecurePass123!;"
  },
  "Redis": {
    "Configuration": "127.0.0.1:6379",
  },
  "OpenIddict": {
    "Applications": {
      "PermissionService_App": {
        "ClientId": "swagger_app"
      },
      "PermissionService_Swagger": {
        "ClientId": "swagger",
        "RootUrl": "https://localhost:44366/"
      }
    }
  },
  "AuthServer": {
    "Authority": "https://localhost:44366",
    "RequireHttpsMetadata": true,
    "CertificatePassPhrase": "78565a47-b0b5-42b8-a338-27c0c0dbed16"
  },
  "StringEncryption": {
    "DefaultPassPhrase": "x5h2eeKptBrW0QPX"
  }

}
