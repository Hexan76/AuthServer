{
  "App": {
    "SelfUrl": "https://localhost:44315",
    "HealthCheckUrl": "/health-status"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "Logs/logs.txt"
              }
            }
          ]
        }
      },
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      }
    ]
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5433;Database=AuthServer;User ID=admin;Password=SecurePass123!;"
  },
  "AuthServer": {
    "Authority": "https://localhost:44315",
    "RequireHttpsMetadata": true,
    "CertificatePath": "cert.pfx",
    "CertificatePassword": "xxx",
    "CertificatePassPhrase": "7c6b4e14-dfda-424b-99bb-9db33d5ecb2c"
  },
  "OpenIddict": {
    "Flows": {
      "AuthorizationCode": true,
      "ClientCredentials": true,
      "RefreshToken": true
    }
  },
  "OpenIddictClients": [
    {
      "ClientId": "swagger",
      "Type": "public",
      "Flow": "authorization_code",
      "RedirectUris": [ "https://localhost/swagger/oauth2" ]
    }
  ],
  "Authentication": {
    "Google": {
      "Enabled": true,
      "ClientId": "...",
      "ClientSecret": "..."
    },
    "Github": {
      "Enabled": true,
      "ClientId": "...",
      "ClientSecret": "..."
    },
    "Microsoft": {
      "Enabled": false
    }
  },
  "StringEncryption": {
    "DefaultPassPhrase": "sqA75O7VrTYXdubP"
  }
}
